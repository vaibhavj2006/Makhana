# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=5000
NODE_ENV=development

# MongoDB (Atlas connection string works fine here too)
MONGO_URI=mongodb://127.0.0.1:27017/makhana_shop

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_NAME=mk_token

# Google Sign-In (https://console.cloud.google.com/apis/credentials)
# Create an OAuth 2.0 Client ID of type "Web application".
# Add your frontend URL (e.g. http://localhost:3000) under "Authorized JavaScript origins".
# Leave blank to disable the "Continue with Google" button.
GOOGLE_CLIENT_ID=

# Frontend origin allowed to call this API (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5500

# Set to true once you're serving over HTTPS in production
SECURE_COOKIES=false

# Email (Resend — https://resend.com)
# Leave RESEND_API_KEY blank to skip sending emails (they'll just be logged instead).
# Free tier note: until you verify your own domain in Resend, you can only send
# emails to the address you signed up to Resend with.
RESEND_API_KEY=
EMAIL_FROM=Pond & Puff <onboarding@resend.dev>
